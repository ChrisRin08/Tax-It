<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_white">

    <!-- DARK PANEL (TOP) -->
    <LinearLayout
        android:id="@+id/dark_panel"
        style="@style/TaxIt.DarkPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- Subtotal row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_subtotal"
                style="@style/TaxIt.Label"/>

            <TextView
                android:id="@+id/tv_subtotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/value_default"
                style="@style/TaxIt.Value"/>
        </LinearLayout>

        <!-- Discount row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_discount"
                style="@style/TaxIt.Label"/>

            <TextView
                android:id="@+id/tv_discount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/value_default"
                style="@style/TaxIt.Value"/>
        </LinearLayout>

        <!-- Tax row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_tax"
                style="@style/TaxIt.Label"/>

            <TextView
                android:id="@+id/tv_tax"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/value_default"
                style="@style/TaxIt.Value"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_secondary"
            android:layout_marginBottom="8dp"/>

        <!-- Total row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_total"
                style="@style/TaxIt.Label"/>

            <TextView
                android:id="@+id/tv_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/value_default"
                style="@style/TaxIt.TotalValue"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Subtle decorative watermark behind the calculator content -->
    <TextView
        android:id="@+id/watermark_calculator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/accent_light"
        android:textSize="92sp"
        android:textStyle="bold"
        android:alpha="0.55"
        android:rotation="-12"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toBottomOf="@id/dark_panel"
        app:layout_constraintBottom_toTopOf="@id/layout_buttons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SCROLLABLE MIDDLE SECTION -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/dark_panel"
        app:layout_constraintBottom_toTopOf="@id/layout_buttons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/transparent"
            android:padding="16dp">

            <!-- ZIP SECTION STATE A (expanded) -->
            <LinearLayout
                android:id="@+id/layout_zip_expanded"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_tax_rate_lookup"
                    android:textColor="@color/text_secondary_dark"
                    android:textSize="14sp"
                    android:letterSpacing="0.08"
                    android:textAllCaps="true"
                    android:layout_marginBottom="8dp"/>

                <!-- ZIP input -->
                <EditText
                    android:id="@+id/et_zip"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/hint_zip"
                    android:inputType="number"
                    android:maxLength="5"
                    android:textColor="@color/text_dark"
                    android:textColorHint="@color/text_hint"
                    android:backgroundTint="@color/red_accent"
                    android:textSize="18sp"
                    android:padding="8dp"
                    android:autofillHints="postalCode"/>

                <!-- Status text -->
                <TextView
                    android:id="@+id/tv_zip_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_loading"
                    android:textColor="@color/text_secondary_dark"
                    android:textSize="14sp"
                    android:visibility="gone"
                    android:layout_marginTop="4dp"/>

                <!-- Rate breakdown card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_rate_breakdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/surface_light"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- State rate -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/label_state_rate"
                                android:textColor="@color/text_secondary_dark"
                                android:textSize="15sp"/>
                            <TextView
                                android:id="@+id/tv_state_rate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.000%"
                                android:textColor="@color/text_dark"
                                android:textSize="16sp"/>
                        </LinearLayout>

                        <!-- County rate -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/label_county_rate"
                                android:textColor="@color/text_secondary_dark"
                                android:textSize="15sp"/>
                            <TextView
                                android:id="@+id/tv_county_rate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.000%"
                                android:textColor="@color/text_dark"
                                android:textSize="16sp"/>
                        </LinearLayout>

                        <!-- City rate -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/label_city_rate"
                                android:textColor="@color/text_secondary_dark"
                                android:textSize="15sp"/>
                            <TextView
                                android:id="@+id/tv_city_rate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.000%"
                                android:textColor="@color/text_dark"
                                android:textSize="16sp"/>
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider"
                            android:layout_marginBottom="8dp"/>

                        <!-- Combined rate -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/label_combined_rate"
                                android:textColor="@color/text_secondary_dark"
                                android:textSize="15sp"/>
                            <TextView
                                android:id="@+id/tv_combined_rate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.000%"
                                android:textColor="@color/red_accent"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ZIP SUMMARY STATE B (collapsed) -->
            <LinearLayout
                android:id="@+id/layout_zip_collapsed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_marginBottom="12dp">

                <!-- Green dot -->
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/circle_green"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tv_zip_summary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:text="Los Angeles, CA — 6.25%"/>

                <TextView
                    android:id="@+id/btn_edit_zip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_edit"
                    android:textColor="@color/red_accent"
                    android:textSize="16sp"
                    android:padding="8dp"/>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="12dp"/>

            <!-- LINE ITEMS -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_line_items"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <!-- Add Item -->
            <TextView
                android:id="@+id/btn_add_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/button_add_item"
                android:textColor="@color/red_accent"
                android:textSize="16sp"
                android:padding="8dp"
                android:layout_marginTop="8dp"/>

            <!-- Whole-order discount -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_discount_percent"
                android:textColor="@color/text_secondary_dark"
                android:textSize="14sp"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/et_discount_percent"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/hint_discount_percent"
                android:inputType="numberDecimal"
                android:maxLength="6"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_hint"
                android:backgroundTint="@color/red_accent"
                android:textSize="18sp"
                android:padding="8dp"
                android:autofillHints=""/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM BUTTONS -->
    <LinearLayout
        android:id="@+id/layout_buttons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/background_white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Calculate Tax — black -->
        <Button
            android:id="@+id/btn_calculate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/button_calculate"
            android:backgroundTint="@color/button_calculate"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:layout_marginEnd="8dp"/>

        <!-- Clear All — purple -->
        <Button
            android:id="@+id/btn_clear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/button_clear"
            android:backgroundTint="@color/button_clear"
            android:textColor="@color/text_primary"
            android:textSize="16sp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
