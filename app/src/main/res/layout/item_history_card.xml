<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/card_white"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- ZIP and city label -->
                <TextView
                    android:id="@+id/tv_history_zip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ZIP: 90001 — Los Angeles"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_history_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="May 11, 2026 12:45 PM"
                    android:textColor="@color/text_secondary_dark"
                    android:textSize="14sp"/>

            </LinearLayout>

            <TextView
                android:id="@+id/btn_delete_history"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/content_desc_delete_history"
                android:padding="8dp"
                android:text="@string/symbol_delete"
                android:textColor="@color/red_accent"
                android:textSize="18sp"/>

        </LinearLayout>

        <!-- Amount row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_amount"
                android:textColor="@color/text_secondary_dark"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/tv_history_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$500.00"
                android:textColor="@color/text_dark"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- Tax row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_tax_applied"
                android:textColor="@color/text_secondary_dark"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/tv_history_tax"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$31.25"
                android:textColor="@color/text_dark"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="8dp"/>

        <!-- Total row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_total_history"
                android:textColor="@color/text_secondary_dark"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/tv_history_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$531.25"
                android:textColor="@color/green_accent"
                android:textSize="17sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
