<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.TaxIt" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background_white</item>
        <item name="android:statusBarColor">@color/panel_dark</item>
        <item name="android:navigationBarColor">@color/nav_bar</item>
        <item name="colorPrimary">@color/red_accent</item>
        <item name="colorPrimaryVariant">@color/panel_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSurface">@color/background_white</item>
        <item name="colorOnSurface">@color/text_dark</item>
    </style>

    <!-- Base style — required for child styles below to work -->
    <style name="TaxIt" />

    <style name="TaxIt.DarkPanel">
        <item name="android:background">@color/panel_dark</item>
        <item name="android:paddingTop">24dp</item>
        <item name="android:paddingBottom">24dp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
    </style>

    <style name="TaxIt.Label">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="TaxIt.Value">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TaxIt.TotalValue">
        <item name="android:textColor">@color/green_accent</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
